# Database
DATABASE_URL="postgresql://meeting_ai:meeting_ai@localhost:5432/meeting_ai?schema=public"

# API / Web
API_PORT=4000
API_PUBLIC_BASE_URL="http://localhost:4000"
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Auth / Email login
AUTH_DISABLED=false
AUTH_SESSION_SECRET=""
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_SECURE=false
EMAIL_CODE_SECRET=""
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_DEV_RETURN=true
PASSWORD_MIN_LENGTH=8
SMTP_HOST=""
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

WEB_BASE_URL="http://localhost:3000"
INTERNAL_RENDER_TOKEN=""

# Doubao / Volcengine ASR
DOUBAO_VOLCENGINE_ASR_ENABLED=false
DOUBAO_VOLCENGINE_ASR_WS_URL="wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async"
DOUBAO_VOLCENGINE_ASR_APP_ID=""
DOUBAO_VOLCENGINE_ASR_ACCESS_TOKEN=""
DOUBAO_VOLCENGINE_ASR_SECRET_KEY=""
DOUBAO_VOLCENGINE_ASR_RESOURCE_ID="volc.seedasr.sauc.duration"
DOUBAO_VOLCENGINE_ASR_REPLACEMENT_WORD_ID=""
DOUBAO_VOLCENGINE_ASR_CONNECT_ID=""
DOUBAO_VOLCENGINE_ASR_SAMPLE_RATE=16000
DOUBAO_VOLCENGINE_ASR_CHUNK_MS=200
DOUBAO_VOLCENGINE_ASR_RECONNECT_ATTEMPTS=2

# LLM
LLM_PROVIDER="model_gateway"
LLM_BASE_URL="http://101.37.38.251:9080/v1/chat/completions"
LLM_API_KEY=""
LLM_MODEL="deepseek-v4-pro"
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=12000
LLM_TIMEOUT_MS=240000
LLM_RETRY_COUNT=1

# Yuque
YUQUE_API_BASE_URL="https://www.yuque.com/api/v2"
YUQUE_TOKEN=""

# Legacy DingTalk / Feishu adapters are disabled in current product flow.
DINGTALK_AUTH_ENABLED=false
FEISHU_CLI_ENABLED=false

# Visual report
VISUAL_REPORT_BASE_URL="http://localhost:3000"
STORAGE_ROOT=""
VISUAL_REPORT_SCREENSHOT_DIR=""
