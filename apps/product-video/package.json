{
  "name": "@meeting-ai-kit/product-video",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts MeetingAiKitIntro out/meeting-ai-kit-intro.mp4 --codec=h264 --pixel-format=yuv420p",
    "still": "remotion still src/index.ts MeetingAiKitIntro out/preview.png --frame=240",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.457",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.457",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
